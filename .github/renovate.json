{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitTypeAll(chore)"
  ],
  "automerge": true,
  "postUpgradeTasks": {
    "commands": [
      "bash .github/scripts/renovate-reset-release.bash"
    ],
    "fileFilters": [
      "copr/**/*.spec"
    ],
    "executionMode": "branch"
  },
  "customDatasources": {
    "nvchecker": {
      "defaultRegistryUrlTemplate": "https://github.com/CAB233/zuoye-copr/releases/download/nvchecker/new_ver.json",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": data.'{{packageName}}'.version }] }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "autoReplaceStringTemplate": "Version:\\s*{{{newValue}}}",
      "datasourceTemplate": "custom.nvchecker",
      "depNameTemplate": "sing-box"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box-testing.spec$/"
      ],
      "matchStrings": [
        "%global\\s+upstream_version\\s*(?<currentValue>\\S+)"
      ],
      "autoReplaceStringTemplate": "%global\\s+upstream_version\\s*{{{newValue}}}",
      "datasourceTemplate": "custom.nvchecker",
      "depNameTemplate": "sing-box-testing"
    }
  ]
}
