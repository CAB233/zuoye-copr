{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitScope(package)"
  ],
  "postUpgradeTasks": {
    // https://github.com/dotnet/dotnet-buildtools-prereqs-docker/blob/6f9f456afbf7243915a4a6d1a7312db6c1c95f0a/eng/renovate.json
    // https://github.com/dotnet/dotnet-buildtools-prereqs-docker/blob/6f9f456afbf7243915a4a6d1a7312db6c1c95f0a/eng/update-llvm-checksums.sh
    "commands": [
      "bash .github/scripts/renovate-reset-release.bash"
    ],
    "dataFileTemplate": "{{{packageFile}}}",
    "fileFilters": [
      "copr/**/*.spec"
    ],
    "executionMode": "branch"
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "SagerNet/sing-box",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box-testing.spec$/"
      ],
      "matchStrings": [
        "%global\\s+upstream_version\\s+(?<currentValue>\\d+\\.\\d+\\.\\d+-(?:alpha|beta|rc)\\.\\d+)"
      ],
      "depNameTemplate": "SagerNet/sing-box",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)qbittorrent-enhanced-edition.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "c0re100/qBittorrent-Enhanced-Edition",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^release-(?<version>.*)$",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)maple-font.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "subframe7536/maple-font",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)deno.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "denoland/deno",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)opencode.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "anomalyco/opencode",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)codex.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "openai/codex",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^rust-v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)ciel.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "AOSC-Dev/ciel-rs",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)papirus-icon-theme.spec$/"
      ],
      "matchStrings": [
        "%define\\s+commit\\s+(?<currentDigest>[a-f0-9]{40})\\n"
      ],
      "packageNameTemplate": "https://github.com/PapirusDevelopmentTeam/papirus-icon-theme",
      "depNameTemplate": "papirus-icon-theme",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "master"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)xcaddy.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "caddyserver/xcaddy",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)fluent-gtk-theme.spec$/"
      ],
      "matchStrings": [
        "%define\\s+commit\\s+(?<currentDigest>[a-f0-9]{40})\\n"
      ],
      "packageNameTemplate": "https://github.com/vinceliuice/Fluent-gtk-theme",
      "depNameTemplate": "Fluent-gtk-theme",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "master"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)qdiskinfo.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "edisionnano/QDiskInfo",
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "copr/**/*.spec"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "ignoreTests": true
    },
    {
      "matchFileNames": [
        "copr/sing-box-testing/sing-box-testing.spec"
      ],
      "ignoreUnstable": true
    }
  ]
}
