{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitTypeAll(chore)"
  ],
  "automerge": true,
  "customDatasources": {
    "nvchecker": {
      "defaultRegistryUrlTemplate": "https://github.com/CAB233/myAUR/releases/download/nvchecker/new_ver.json",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": data.'{{packageName}}'.version }] }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "SagerNet/sing-box",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box-testing.spec$/"
      ],
      "matchStrings": [
        "%global\\s+upstream_version\\s+(?<currentValue>\\d+\\.\\d+\\.\\d+-(?:alpha|beta|rc)\\.\\d+)"
      ],
      "depNameTemplate": "SagerNet/sing-box",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>\\d+\\.\\d+\\.\\d+-(?:alpha|beta|rc)\\.\\d+)$"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "copr/sing-box-testing/sing-box-testing.spec"
      ],
      "matchPackageNames": [
        "SagerNet/sing-box"
      ],
      "ignoreUnstable": false,
      "respectLatest": false
    }
  ]
}
