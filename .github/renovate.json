{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitScope(package)"
  ],
  "automerge": true,
  "postUpgradeTasks": {
    // https://github.com/dotnet/dotnet-buildtools-prereqs-docker/blob/6f9f456afbf7243915a4a6d1a7312db6c1c95f0a/eng/renovate.json
    // https://github.com/dotnet/dotnet-buildtools-prereqs-docker/blob/6f9f456afbf7243915a4a6d1a7312db6c1c95f0a/eng/update-llvm-checksums.sh
    "commands": [
      "bash .github/scripts/renovate-reset-release.bash"
    ],
    "dataFileTemplate": "{{{depName}}}\n{{{packageFile}}}",
    "fileFilters": [
      "copr/**/*.spec"
    ],
    "executionMode": "branch"
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "SagerNet/sing-box",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)sing-box-testing.spec$/"
      ],
      "matchStrings": [
        "%global\\s+upstream_version\\s+(?<currentValue>\\d+\\.\\d+\\.\\d+-(?:alpha|beta|rc)\\.\\d+)"
      ],
      "depNameTemplate": "SagerNet/sing-box",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)qbittorrent-enhanced-edition.spec$/"
      ],
      "matchStrings": [
        "Version:\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "c0re100/qBittorrent-Enhanced-Edition",
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "copr/sing-box-testing/sing-box-testing.spec"
      ],
      "ignoreUnstable": true
    }
  ]
}
